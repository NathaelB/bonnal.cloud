---
import { BackgroundAnimation } from "./background-animation";
import { Icon } from "@iconify/react";
import { Button } from "@explainer/ui";
---

<div
  class="relative px-4 sm:px-6 lg:px-8 flex flex-col pt-24 sm:pt-32 lg:pt-36 overflow-hidden"
>
  <div>
    <div class="absolute inset-0 w-full -z-10">
      <BackgroundAnimation client:load />
    </div>

    <div
      class="absolute inset-0 -z-5 pointer-events-none"
      style="clip-path: inset(0 -100vw 0 -100vw);"
      aria-hidden="true"
    >
      <div
        class="absolute -top-16 -left-16 w-56 h-56 sm:-top-32 sm:-left-32 sm:w-md sm:h-112 rounded-full border-2 border-primary/20"
      >
        <div
          class="absolute inset-0 m-auto w-32 h-32 sm:w-80 sm:h-80 rounded-full border border-primary/20"
        >
        </div>
      </div>

      <div
        class="hidden sm:block absolute -top-24 -right-24 w-80 h-80 rounded-full border-2 border-primary/20"
      >
      </div>

      <div
        class="hidden sm:block absolute top-1/2 -left-16 w-48 h-48 rounded-full border border-primary/14 -translate-y-1/2"
      >
      </div>

      <div
        class="hidden sm:block absolute -bottom-16 -right-16 w-48 h-48 rounded-full border-2 border-primary/18"
      >
      </div>

      <div
        class="hidden sm:block absolute top-1/4 right-[15%] size-3 rounded-full bg-primary/40 blur-[1px]"
      >
      </div>
      <div
        class="hidden sm:block absolute top-[40%] left-[25%] size-2 rounded-full bg-primary/35 blur-[1px]"
      >
      </div>
      <div
        class="hidden sm:block absolute bottom-1/3 right-1/3 size-2.5 rounded-full bg-primary/35 blur-[1px]"
      >
      </div>
    </div>

    <div
      class="hidden sm:block absolute bottom-0 left-[33%] -translate-x-1/2 -z-5 pointer-events-none"
      aria-hidden="true"
    >
      <div
        class="absolute -bottom-24 -left-32 w-64 h-64 rounded-full border-2 border-primary/16"
      >
      </div>
    </div>

    <div
      class="absolute bottom-0 inset-x-0 h-px bg-linear-to-r from-transparent via-border to-transparent"
    >
    </div>

    <div class="w-full max-w-6xl mx-auto pb-16 lg:pb-20">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <a
            href="#projects"
            rel="noopener noreferrer"
            class="rounded-lg font-semibold inline-flex items-center gap-2 transition-colors px-4 py-1.5 text-xs ring ring-inset ring-primary/50 text-primary hover:bg-primary/10 active:bg-primary/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
          >
            <span data-t="hero.badge">Rust, IAM and distributed systems</span>
            <Icon icon="mdi:arrow-right" className="size-3.5" client:load />
          </a>

          <h1
            class="mt-6 text-4xl text-pretty tracking-tight text-foreground font-semibold sm:text-6xl"
            data-t="hero.title"
          >
            Nathael Bonnal, open source engineer for critical platforms
          </h1>
          <p
            class="text-lg sm:text-xl/8 text-muted-foreground text-pretty mt-6 max-w-2xl"
            data-t="hero.description"
          >
            I build IAM primitives, Rust backends and distributed architectures for systems that need to stay readable, operable and open.
          </p>

          <div class="pt-8 flex flex-wrap gap-x-4 gap-y-3">
            <Button size="lg" className="cursor-pointer" client:load>
              <a href="#projects" class="flex gap-2" rel="noopener noreferrer">
                <span data-t="hero.primaryAction">View my projects</span>
                <Icon
                  icon="mdi:arrow-right"
                  aria-hidden="true"
                  className="size-5"
                  client:load
                />
              </a>
            </Button>
            <Button
              variant="outline"
              size="lg"
              className="cursor-pointer"
              client:load
            >
              <a
                href="https://github.com/nathaelb"
                class="flex gap-2"
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon
                  icon="mdi:github"
                  aria-hidden="true"
                  className="size-5"
                  client:load
                />
                <span data-t="hero.secondaryAction">GitHub</span>
              </a>
            </Button>
          </div>

          <div class="mt-8 flex gap-x-8 gap-y-3 flex-wrap">
            <div class="flex items-center gap-2 text-sm text-muted-foreground">
              <Icon icon="mdi:language-rust" className="size-4 text-primary" client:load />
              <span data-t="hero.openSource">Rust backend</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-muted-foreground">
              <Icon icon="mdi:shield-key-outline" className="size-4 text-primary" client:load />
              <span data-t="hero.license">IAM and security</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-muted-foreground">
              <Icon icon="mdi:source-branch" className="size-4 text-primary" client:load />
              <span data-t="hero.downloads">Open source lead</span>
            </div>
          </div>

          <div class="mt-7 flex w-fit items-center gap-4">
            <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">
              Currently at
            </span>
            <span class="flex h-10 w-10 items-center justify-center rounded-md bg-white p-0.5 shadow-sm">
              <img
                src="/companies/cloud-iam.png"
                alt="Cloud-IAM"
                class="max-h-full max-w-full object-contain"
                loading="lazy"
              />
            </span>
          </div>
        </div>

        <div class="relative">
          <div class="overflow-hidden rounded-lg border bg-background">
            <img
              src="/nathael.jpg"
              alt="Nathael Bonnal"
              width="720"
              height="720"
              class="aspect-square w-full object-cover"
              loading="eager"
            />
          </div>
          <div class="mt-4 grid grid-cols-3 gap-3">
            <div class="rounded-lg border bg-background p-4">
              <p class="text-2xl font-semibold text-foreground">Rust</p>
              <p class="mt-1 text-xs text-muted-foreground">services, CLI, APIs</p>
            </div>
            <div class="rounded-lg border bg-background p-4">
              <p class="text-2xl font-semibold text-foreground">IAM</p>
              <p class="mt-1 text-xs text-muted-foreground">Keycloak, OIDC</p>
            </div>
            <div class="rounded-lg border bg-background p-4">
              <p class="text-2xl font-semibold text-foreground">K8s</p>
              <p class="mt-1 text-xs text-muted-foreground">OPA, AuthZen, MCP</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
