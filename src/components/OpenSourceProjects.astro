---
/**
 * Open Source Projects section.
 *
 * 3-column card grid: FerrisKey, FerrisPass, Aether.
 * Same card style as WhatIBuild secondary cards.
 */

interface Project {
  name: string;
  description: string;
  tags: string[];
  github: string;
  status: "active" | "wip";
}

const projects: Project[] = [
  {
    name: "FerrisKey",
    description:
      "FerrisKey is an open-source identity and access management system built in Rust, designed for cloud-native and distributed environments. It focuses on modern authentication, scalable architecture, and externalized authorization.",
    tags: ["Rust", "IAM", "Kubernetes", "OAuth2"],
    github: "https://github.com/ferriskey/ferriskey",
    status: "active",
  },
  {
    name: "FerrisPass",
    description:
      "100% open-source password manager built in Rust. Designed as a self-hostable alternative to ProtonPass with a strong focus on security and data sovereignty.",
    tags: ["Rust", "Security", "Self-hosted", "Encryption"],
    github: "https://github.com/ferrislabs/ferrispass",
    status: "wip",
  },
  {
    name: "Aether",
    description:
      "IAM as a Service platform built in Rust with a micro-services control plane architecture. Designed for scalable, cloud-native identity management at scale.",
    tags: ["Rust", "IAM", "Micro-services", "Control Plane"],
    github: "https://github.com/nathaelb/aether",
    status: "wip",
  },
];
---

<section id="projects" class="osp section" aria-labelledby="osp-heading">
  <div class="container">
    <h2 id="osp-heading" class="osp__heading" data-animate>Open Source Projects</h2>

    <ul class="osp__grid" data-animate-children aria-label="Open source projects">
      {
        projects.map((project) => (
          <li class="osp__card">
            <div class="osp__card-header">
              <h3 class="osp__card-name">{project.name}</h3>
              <span class={`osp__status osp__status--${project.status}`}>
                {project.status === "active" ? "Active" : "WIP"}
              </span>
            </div>

            <p class="osp__card-desc">{project.description}</p>

            <ul class="osp__tags" aria-label="Technologies">
              {project.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>

            <a
              href={project.github}
              class="osp__link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`View ${project.name} on GitHub`}
            >
              GitHub →
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .osp {
    border-bottom: 1px solid var(--color-border);
  }

  .osp__heading {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-ink-primary);
    margin-bottom: 2rem;
  }

  /* ── 3-column grid ── */
  .osp__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .osp__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .osp__grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  /* ── Card ── */
  .osp__card {
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .osp__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .osp__card-name {
    font-size: var(--font-size-md);
    font-weight: 700;
    color: var(--color-ink-primary);
  }

  /* ── Status badge ── */
  .osp__status {
    font-size: var(--font-size-xs);
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .osp__status--active {
    background-color: #dcfce7;
    color: #166534;
  }

  .osp__status--wip {
    background-color: #fef9c3;
    color: #854d0e;
  }

  /* ── Description ── */
  .osp__card-desc {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-ink-secondary);
    flex: 1;
  }

  /* ── Tech tags ── */
  .osp__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .osp__tags li {
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--color-ink-secondary);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.125rem 0.625rem;
  }

  /* ── GitHub link ── */
  .osp__link {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-accent-blue);
    text-decoration: none;
    transition: opacity 0.15s ease;
    align-self: flex-start;
  }

  .osp__link:hover {
    opacity: 0.75;
  }
</style>
