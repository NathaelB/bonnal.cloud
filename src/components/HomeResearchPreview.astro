---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

type ResearchChapter = CollectionEntry<"research">;

type ResearchDocument = {
  document: string;
  title: string;
  description: string;
  chapters: ResearchChapter[];
};

const allChapters = (await getCollection("research", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.chapter - b.data.chapter,
);

const docs = new Map<string, ResearchDocument>();

for (const chapter of allChapters) {
  const existing = docs.get(chapter.data.document);
  if (existing) {
    existing.chapters.push(chapter);
    continue;
  }

  docs.set(chapter.data.document, {
    document: chapter.data.document,
    title: chapter.data.documentTitle,
    description: chapter.data.documentDescription,
    chapters: [chapter],
  });
}

const documents = Array.from(docs.values()).slice(0, 2);

function chapterLink(chapter: ResearchChapter) {
  const [document, chapterSlug] = chapter.slug.split("/");
  if (!document || !chapterSlug) {
    throw new Error(`Invalid research slug format: ${chapter.slug}`);
  }
  return `/research/${document}/${chapterSlug}/`;
}
---

<section class="section home-research" aria-label="Latest research documents">
  <div class="container">
    <div class="home-research__header" data-animate>
      <p class="home-research__overline">Research</p>
      <h2>Latest research documents</h2>
      <a class="home-research__all" href="/research/">Go to research home →</a>
    </div>

    {
      documents.length > 0 ? (
        <ul class="home-research__list" data-animate-children>
          {documents.map((doc) => {
            const chapters = doc.chapters.sort((a, b) => a.data.chapter - b.data.chapter);
            const first = chapters[0];

            return (
              <li class="home-research__item">
                <a href={chapterLink(first)} class="home-research__link">
                  <p class="home-research__meta">{chapters.length} chapters</p>
                  <h3>{doc.title}</h3>
                  <p>{doc.description}</p>
                </a>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="home-research__empty">No research document published yet.</p>
      )
    }
  </div>
</section>

<style>
  .home-research {
    border-top: 1px solid var(--color-border);
  }

  .home-research__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    margin-bottom: 1.25rem;
  }

  .home-research__overline {
    width: 100%;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-blue);
    font-weight: 600;
  }

  .home-research__header h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .home-research__all {
    color: var(--color-accent-blue);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }

  .home-research__all:hover {
    opacity: 0.8;
  }

  .home-research__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 960px) {
    .home-research__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .home-research__item {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    border-radius: var(--radius-md);
  }

  .home-research__link {
    display: block;
    padding: 1rem;
  }

  .home-research__meta {
    color: var(--color-ink-muted);
    font-size: var(--font-size-xs);
    margin-bottom: 0.4rem;
  }

  .home-research__link h3 {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-snug);
  }

  .home-research__link p {
    margin-top: 0.5rem;
  }

  .home-research__empty {
    color: var(--color-ink-secondary);
  }
</style>
