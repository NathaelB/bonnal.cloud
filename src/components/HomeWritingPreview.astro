---
import { getCollection, type CollectionEntry } from "astro:content";

type BlogEntry = CollectionEntry<"blog">;
type ResearchChapterEntry = CollectionEntry<"documents">;
type ResearchDocumentEntry = CollectionEntry<"documentIndex">;

type WritingPreviewItem = {
  kind: "article" | "document";
  title: string;
  description: string;
  href: string;
  publishDate: Date;
  tags: string[];
  ogImage: string | null;
};

const posts = (await getCollection("blog", ({ data }) => !data.draft)).map<WritingPreviewItem>((post: BlogEntry) => ({
  kind: "article",
  title: post.data.title,
  description: post.data.description,
  href: `/blog/${post.slug}/`,
  publishDate: post.data.publishDate,
  tags: post.data.tags,
  ogImage: `/og/${post.slug}.png`,
}));

const researchChapters = await getCollection("documents");
const researchDocuments = await getCollection(
  "documentIndex",
  ({ data }) => !data.draft,
);

const chaptersByDocument = new Map<string, ResearchChapterEntry[]>();
for (const chapter of researchChapters) {
  const arr = chaptersByDocument.get(chapter.data.document);
  if (arr) {
    arr.push(chapter);
  } else {
    chaptersByDocument.set(chapter.data.document, [chapter]);
  }
}

const researchDocs: WritingPreviewItem[] = researchDocuments
  .map((doc: ResearchDocumentEntry) => {
    const chapters = (chaptersByDocument.get(doc.data.document) ?? []).sort(
      (a, b) => a.data.chapter - b.data.chapter,
    );
    const first = chapters[0];
    if (!first) return null;

    const [, chapterSlug] = first.slug.split("/");
    if (!chapterSlug) {
      throw new Error(`Invalid research slug format: ${first.slug}`);
    }

    return {
      kind: "document",
      title: doc.data.documentTitle,
      description: doc.data.documentDescription,
      href: `/documents/${doc.data.document}/${chapterSlug}/`,
      publishDate: doc.data.publishDate,
      tags: doc.data.tags,
      ogImage: null,
    } satisfies WritingPreviewItem;
  })
  .filter((doc): doc is WritingPreviewItem => doc !== null);

const items = [...posts, ...researchDocs]
  .sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime())
  .slice(0, 4);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  dateStyle: "long",
});
---

<section class="section home-writing" aria-label="Latest writing">
  <div class="container">
    <div class="home-writing__header" data-animate>
      <p class="home-writing__overline">Writing</p>
      <h2>Latest articles and research</h2>
      <a class="home-writing__all" href="/writing/">Open writing hub →</a>
    </div>

    {
      items.length > 0 ? (
        <ul class="home-writing__list" data-animate-children>
          {items.map((item) => (
            <li class="home-writing__item">
              <a href={item.href} class="home-writing__link">
                <div class="home-writing__banner" aria-hidden="true">
                  {item.ogImage ? (
                    <img src={item.ogImage} alt="" loading="lazy" decoding="async" />
                  ) : (
                    <div class="home-writing__banner-placeholder" />
                  )}
                </div>
                <div class="home-writing__info">
                  <p class="home-writing__meta">
                    <span class:list={["home-writing__kind", item.kind === "research" && "home-writing__kind--research"]}>
                      {item.kind === "research" ? "Research" : "Article"}
                    </span>
                    {item.tags.slice(0, 2).map((tag) => (
                      <span class="home-writing__tag">{tag}</span>
                    ))}
                    <span class="home-writing__date">{dateFormatter.format(item.publishDate)}</span>
                  </p>
                  <h3 class="home-writing__title">{item.title}</h3>
                  <p class="home-writing__desc">{item.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="home-writing__empty">No writing published yet.</p>
      )
    }
  </div>
</section>

<style>
  .home-writing {
    border-top: 1px solid var(--color-border);
  }

  .home-writing__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    margin-bottom: 1.25rem;
  }

  .home-writing__overline {
    width: 100%;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-blue);
    font-weight: 600;
  }

  .home-writing__header h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .home-writing__all {
    color: var(--color-accent-blue);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }

  .home-writing__all:hover {
    opacity: 0.8;
  }

  .home-writing__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 960px) {
    .home-writing__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Card */
  .home-writing__item {
    border-radius: var(--radius-md);
    overflow: hidden;
    position: relative;
    height: 380px;
    border: 1px solid var(--color-border);
  }

  .home-writing__link {
    display: block;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  /* Banner (OG image) */
  .home-writing__banner {
    position: absolute;
    inset: 0;
  }

  .home-writing__banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
    display: block;
  }

  .home-writing__banner-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 50%, #7c3aed 100%);
  }

  /* Sliding info panel */
  .home-writing__info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100%;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: 1.1rem 1.25rem 1.25rem;
    transform: translateY(57%);
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .home-writing__item:hover .home-writing__info {
    transform: translateY(0);
  }

  /* Meta row */
  .home-writing__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    font-size: var(--font-size-xs);
    color: var(--color-ink-muted);
    margin: 0;
  }

  .home-writing__kind {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.06rem 0.45rem;
    color: var(--color-accent-blue);
  }

  .home-writing__kind--document {
    color: #0f766e;
  }

  .home-writing__tag {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.06rem 0.45rem;
    color: var(--color-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.65rem;
    font-weight: 500;
  }

  .home-writing__date {
    margin-left: auto;
  }

  /* Title */
  .home-writing__title {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-snug);
    margin: 0;
  }

  /* Description — hidden by default, fades in on hover */
  .home-writing__desc {
    font-size: var(--font-size-sm);
    color: var(--color-ink-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
    opacity: 0;
    transition: opacity 0.2s ease 0.18s;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .home-writing__item:hover .home-writing__desc {
    opacity: 1;
  }

  .home-writing__empty {
    color: var(--color-ink-secondary);
  }
</style>
