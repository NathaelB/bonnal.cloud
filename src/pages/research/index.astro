---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";

type ResearchChapter = CollectionEntry<"research">;
type ResearchDocument = CollectionEntry<"researchDocuments">;

type ResearchDocumentWithChapters = {
  document: string;
  title: string;
  description: string;
  tags: string[];
  chapters: ResearchChapter[];
  publishDate: Date;
  appearanceOrder?: number;
};

const allChapters = (await getCollection("research")).sort(
  (a, b) => a.data.chapter - b.data.chapter,
);

const chapterByDocument = new Map<string, ResearchChapter[]>();
for (const chapter of allChapters) {
  const chapters = chapterByDocument.get(chapter.data.document);
  if (chapters) {
    chapters.push(chapter);
  } else {
    chapterByDocument.set(chapter.data.document, [chapter]);
  }
}

const researchDocuments = (await getCollection(
  "researchDocuments",
  ({ data }) => !data.draft,
)).sort((a, b) => {
  const aOrder = a.data.appearanceOrder ?? Number.MAX_SAFE_INTEGER;
  const bOrder = b.data.appearanceOrder ?? Number.MAX_SAFE_INTEGER;
  if (aOrder !== bOrder) return aOrder - bOrder;
  return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});

const documents: ResearchDocumentWithChapters[] = researchDocuments
  .map((doc: ResearchDocument) => ({
    document: doc.data.document,
    title: doc.data.documentTitle,
    description: doc.data.documentDescription,
    tags: doc.data.tags,
    chapters: (chapterByDocument.get(doc.data.document) ?? []).sort(
      (a, b) => a.data.chapter - b.data.chapter,
    ),
    publishDate: doc.data.publishDate,
    appearanceOrder: doc.data.appearanceOrder,
  }))
  .filter((doc) => doc.chapters.length > 0);

function getChapterSlug(chapter: ResearchChapter) {
  const parts = chapter.slug.split("/");
  if (parts.length < 2) {
    throw new Error(`Invalid research slug format: ${chapter.slug}`);
  }
  return parts[1];
}
---

<Layout
  title="Research — Nathael B."
  description="Long-form research documents and engineering notes."
>
  <main id="main-content" class="research-page">
    <section class="section">
      <div class="container">
        <header class="research-header" data-animate>
          <p class="research-overline">Research</p>
          <h1>Research Documents</h1>
          <p class="research-intro">
            Long-form documents split into chapters for readability and navigation.
          </p>
        </header>

        {
          documents.length > 0 ? (
            <ul class="research-list" data-animate-children>
              {documents.map((doc) => {
                const chapters = doc.chapters.sort((a, b) => a.data.chapter - b.data.chapter);
                const firstChapter = chapters[0];
                const firstChapterSlug = getChapterSlug(firstChapter);

                return (
                  <li class="research-item">
                    <article>
                      <p class="research-meta">
                        {chapters.length} chapters · {chapters.reduce((sum, c) => sum + (c.data.estimatedReadMinutes ?? 0), 0)}
                        min estimated reading
                      </p>

                      <h2>{doc.title}</h2>
                      <p>{doc.description}</p>

                      {doc.tags.length > 0 && (
                        <ul class="research-tags" aria-label="Research tags">
                          {doc.tags.map((tag) => <li>{tag}</li>)}
                        </ul>
                      )}

                      <a href={`/research/${doc.document}/${firstChapterSlug}/`} class="research-link">
                        Open document →
                      </a>
                    </article>
                  </li>
                );
              })}
            </ul>
          ) : (
            <p class="research-empty">No research document published yet.</p>
          )
        }
      </div>
    </section>
  </main>
</Layout>

<style>
  .research-page {
    min-height: 70vh;
  }

  .research-header {
    max-width: 48rem;
    display: grid;
    gap: 0.8rem;
    margin-bottom: 2rem;
  }

  .research-overline {
    font-size: var(--font-size-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-blue);
    font-weight: 600;
  }

  .research-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .research-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .research-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    padding: 1.2rem;
  }

  .research-meta {
    color: var(--color-ink-muted);
    font-size: var(--font-size-xs);
    margin-bottom: 0.5rem;
  }

  .research-item h2 {
    font-size: var(--font-size-2xl);
  }

  .research-item p {
    margin-top: 0.5rem;
  }

  .research-tags {
    list-style: none;
    margin: 1rem 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .research-tags li {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-size: var(--font-size-xs);
  }

  .research-link {
    color: var(--color-accent-blue);
    font-size: var(--font-size-sm);
    font-weight: 600;
  }
</style>
