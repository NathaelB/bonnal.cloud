---
/**
 * Base layout — wraps every page.
 *
 * Injects global styles, fonts, SEO head, and page shell.
 * No client-side JS unless explicitly added per page.
 */
import SEO from "@components/SEO.astro";
import type { SiteMeta } from "@lib/site";
import "@styles/global.css";

interface Props extends SiteMeta {
  class?: string;
}

const { class: className, ...seoProps } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f7f6f3" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.png" />

    <!--
      Inter font via Bunny (GDPR-friendly, no Google tracking).
      Preconnect reduces latency; display=swap prevents FOIT.
    -->
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=inter:400,500,600,700,800&display=swap"
    />

    <!-- SEO meta tags (title, description, OG, Twitter, JSON-LD) -->
    <SEO {...seoProps} />

    <!-- Sitemap autodiscovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class={className}>
    <slot />

    <!--
      Scroll-triggered animations via IntersectionObserver.
      Targets: [data-animate] (section-level fade-up)
               [data-animate-children] (staggered children)
      Vanilla JS — no framework, ~400 bytes, loads after HTML is parsed.
    -->
    <script is:inline>
      (function () {
        var els = document.querySelectorAll("[data-animate], [data-animate-children]");
        if (!els.length) return;

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );

        els.forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
